# Create backend/.env from this file and add your key. Never commit the real file.
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: use a specific model available in your OpenRouter account.
OPENROUTER_MODEL=openrouter/free
# Comma-separated frontend origins for local development or deployment.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
